# GEMINI_API_KEY: Required for Gemini AI API calls if any.
# AI Studio automatically injects this at runtime from user secrets.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# APP_URL="MY_APP_URL"

# Firebase Client Configuration for Production Deployment (Netlify Environment Variables)
# Prefix client variables with VITE_ to expose them to the React frontend application compiled by Vite
# VITE_FIREBASE_API_KEY="your-firebase-api-key"
# VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="your-project-id"
# VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
# VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
# VITE_FIREBASE_APP_ID="your-app-id"
# VITE_FIREBASE_MEASUREMENT_ID="your-measurement-id-optional"
# VITE_FIREBASE_FIRESTORE_DATABASE_ID="your-firestore-database-id-default-if-empty"

# Netlify secrets scanning configuration to prevent false positives during deployment
# SECRETS_SCAN_ENABLED="false"
# SECRETS_SCAN_OMIT_PATHS="firebase-applet-config.json"
# SECRETS_SCAN_OMIT_KEYS="VITE_FIREBASE_API_KEY,VITE_FIREBASE_AUTH_DOMAIN"
