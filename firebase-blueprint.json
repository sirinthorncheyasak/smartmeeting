{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Represents a meeting room booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "cancelled"] },
        "requesterEmail": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterDepartment": { "type": "string" },
        "requesterPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "cancelledReason": { "type": "string" }
      },
      "required": ["id", "title", "roomId", "roomName", "startTime", "endTime", "status", "requesterEmail", "requesterName", "requesterDepartment", "requesterPhone", "createdAt", "updatedAt"]
    },
    "Room": {
      "title": "Room",
      "description": "Represents a meeting room inside the university",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "location": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "name", "capacity", "location", "active"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Represents a university staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "fullName": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "extension": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "employeeId", "fullName", "department", "email", "phone", "extension", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Represents an admin",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of meeting bookings"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of available meeting rooms"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Collection of authorized staff details indexed by staffId"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of admin emails"
    }
  }
}
