{
  "entities": {
    "Document": {
      "title": "Document",
      "description": "Represents an inbound or outbound tracking document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["inbound", "outbound"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "documentNumber": { "type": "string" },
        "direction": { "type": "string", "enum": ["in", "out"] },
        "status": { "type": "string", "enum": ["draft", "pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdByName": { "type": "string" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "object", "description": "Timestamp" },
        "createdAt": { "type": "object", "description": "Timestamp" },
        "updatedAt": { "type": "object", "description": "Timestamp" }
      },
      "required": ["id", "type", "title", "direction", "status", "createdBy", "createdByName", "createdAt", "updatedAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System audit logs tracking actions made on documents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "documentId": { "type": "string" },
        "actor": { "type": "string" },
        "timestamp": { "type": "object", "description": "Timestamp" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "action", "documentId", "actor", "timestamp"]
    },
		"Counter": {
			"title": "Counter",
			"description": "Saves sequential monthly running numbers securely",
			"type": "object",
			"properties": {
				"id": { "type": "string" },
				"lastRunningNumber": { "type": "number" },
				"updatedAt": { "type": "object" }
			},
			"required": ["id", "lastRunningNumber", "updatedAt"]
		},
		"Admin": {
			"title": "Admin",
			"description": "Represents an authorized administrator email",
			"type": "object",
			"properties": {
				"email": { "type": "string" },
				"assignedBy": { "type": "string" },
				"assignedAt": { "type": "object", "description": "Timestamp" }
			},
			"required": ["email", "assignedBy", "assignedAt"]
		}
  },
  "firestore": {
    "/admins/{email}": {
      "schema": "Admin",
      "description": "Registered and authorized admin users"
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Collection of documents with tracking statistics"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit trails for actions executed in the system"
    },
    "/counters/{counterId}": {
      "schema": "Counter",
      "description": "Locking document counter sequence by month"
    }
  }
}
