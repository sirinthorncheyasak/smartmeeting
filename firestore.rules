rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- reusable global helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Enforce BU email domain or admin override (using case-insensitive lowercase endsWith)
    function isBU() {
      return isSignedIn() && (
        request.auth.token.email.lower().endsWith("@bu.ac.th") ||
        request.auth.token.email.lower() == "kulachet.l@bu.ac.th"
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "kulachet.l@bu.ac.th" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEmailId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    function isValidAdmin(data) {
      return data.email is string 
        && (data.email.lower().endsWith("@bu.ac.th") || data.email.lower() == "kulachet.l@bu.ac.th")
        && data.assignedBy is string
        && data.assignedBy.size() <= 200
        && data.assignedAt is timestamp;
    }

    // Helper shortcuts
    function incoming() {
      return request.resource.data;
    }

    // Always use .get() on resource.data map to handle optional/missing fields safely
    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidDocument(data) {
      return data.id is string 
        && data.type in ["inbound", "outbound"]
        && data.title is string && data.title.size() <= 300
        && data.direction in ["in", "out"]
        && data.status in ["draft", "pending", "approved", "rejected"]
        && data.createdBy is string && data.createdBy.size() <= 200
        && data.createdByName is string && data.createdByName.size() <= 200;
    }

    // --- Collection Matching Blocks ---

    // Documents Collection
    match /documents/{documentId} {
      // Staff can read their own documents, admins can read all documents
      allow get, list: if isBU() && (
        isAdmin() || 
        existing().get('createdBy', '').lower() == request.auth.token.email.lower()
      );

      // Anyone within BU can create standard inbound/outbound records
      allow create: if isBU() 
        && isValidId(documentId) 
        && isValidDocument(incoming())
        && (incoming().get('createdBy', '').lower() == request.auth.token.email.lower())
        && incoming().id == documentId
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Staff can modify drafts or cancel pending; Admins can approve/reject (terminal states)
      allow update: if isBU()
        && isValidDocument(incoming())
        && incoming().updatedAt == request.time
        // Protect key immutable properties
        && incoming().id == existing().id
        && (incoming().get('createdBy', '').lower() == existing().get('createdBy', '').lower())
        && incoming().type == existing().type
        && incoming().direction == existing().direction
        && incoming().createdAt == existing().createdAt
        && (
          isAdmin() || 
          (
            // Case 2: Owner can edit/update if the current document is still in draft or pending state
            (existing().get('createdBy', '').lower() == request.auth.token.email.lower())
            && existing().get('status', 'draft') in ["draft", "pending"]
            // If updating as a non-admin, they cannot bypass approval steps (e.g., they cannot mark as approved)
            && incoming().get('status', 'draft') in ["draft", "pending"]
          )
        );

      allow delete: if isAdmin();
    }

    // Audit Logs Collection
    match /auditLogs/{logId} {
      // Admin can read all logs, staff can read logs they triggered
      allow get, list: if isBU() && (
        isAdmin() ||
        existing().get('actor', '').lower() == request.auth.token.email.lower()
      );

      // Creation is allowed when auditing a valid action
      allow create: if isBU()
        && isValidId(logId)
        && (incoming().get('actor', '').lower() == request.auth.token.email.lower())
        && incoming().id == logId
        && incoming().timestamp == request.time;

      allow update, delete: if false; // Audit logs are immutable
    }

    // Running Counters Collection
    match /counters/{counterId} {
      // Need read & write for transaction increments when generating sequence numbers
      allow read, write: if isBU() 
        && isValidId(counterId);
    }

    // Admins Collection
    match /admins/{email} {
      allow get: if isBU() && (email.lower() == request.auth.token.email.lower());
      allow list: if isAdmin();
      allow create, update: if isAdmin() 
        && isValidEmailId(email) 
        && isValidAdmin(incoming())
        && (email.lower() == incoming().get('email', '').lower());
      allow delete: if isAdmin() && email.lower() != "kulachet.l@bu.ac.th";
    }
  }
}
